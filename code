  digitalWrite(F,LOW);
  digitalWrite(A,HIGH);
  digitalWrite(B,HIGH);
  digitalWrite(E,HIGH);
  digitalWrite(D,HIGH);
  digitalWrite(C,LOW);
 
   delay(delayTime);
  //1
digitalWrite(G,LOW);
  digitalWrite(F,LOW);
  digitalWrite(A,LOW);
  digitalWrite(B,HIGH);
  digitalWrite(E,LOW);
  digitalWrite(D,LOW);
  digitalWrite(C,HIGH);
   delay(delayTime);
  //0
 digitalWrite(G,LOW);
  digitalWrite(F,HIGH);
  digitalWrite(A,HIGH);
  digitalWrite(B,HIGH);
  digitalWrite(E,HIGH);
  digitalWrite(D,HIGH);
  digitalWrite(C,HIGH);
 
   delay(delayTime);
}
